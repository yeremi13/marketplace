{
  "rewrites": [
    { "source": "/comprar", "destination": "/comprador.html" },
    { "source": "/vender", "destination": "/vendedor.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
